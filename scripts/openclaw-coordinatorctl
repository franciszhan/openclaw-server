#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
PROJECT_ROOT=$(cd -- "${SCRIPT_DIR}/.." && pwd)
CANDIDATES=()

if [[ -n "${OPENCLAW_HOST_ROOT:-}" ]]; then
  CANDIDATES+=("${OPENCLAW_HOST_ROOT}")
fi
CANDIDATES+=("${PROJECT_ROOT}" "/opt/openclaw-host")

for candidate in "${CANDIDATES[@]}"; do
  if [[ -d "${candidate}/src/openclaw_coordinator" ]]; then
    PROJECT_ROOT="${candidate}"
    break
  fi
done

if [[ ! -d "${PROJECT_ROOT}/src/openclaw_coordinator" ]]; then
  echo "could not locate openclaw_coordinator sources" >&2
  exit 1
fi

export PYTHONPATH="${PROJECT_ROOT}/src${PYTHONPATH:+:${PYTHONPATH}}"
exec python3 -m openclaw_coordinator.cli "$@"
